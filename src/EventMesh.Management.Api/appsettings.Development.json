{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "ManagementApi": {
    "ApiKeys": [ "dev-api-key-change-in-production" ],
    "Jwt": {
      "RequireAuthentication": false
    }
  },
  "EventMesh": {
    "TransportSettings": {
      "rabbitmq": {
        "Host": "localhost",
        "Port": "5672",
        "VirtualHost": "eventmesh",
        "Username": "eventmesh",
        "Password": "eventmesh",
        "ManagementUrl": "http://localhost:15672"
      },
      "kafka": {
        "BootstrapServers": "localhost:9092"
      },
      "nats": {
        "Url": "nats://localhost:4222",
        "MonitoringUrl": "http://localhost:8222"
      },
      "redis": {
        "ConnectionString": "localhost:6379"
      },
      "postgres": {
        "ConnectionString": "Host=localhost;Port=5432;Database=eventmesh;Username=eventmesh;Password=eventmesh"
      }
    }
  }
}
