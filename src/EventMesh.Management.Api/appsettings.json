{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ManagementApi": {
    "ApiKeys": [ "dev-api-key-change-in-production" ],
    "DemoMode": false,
    "AllowedOrigins": [],
    "Jwt": {
      "Authority": "",
      "Audience": "eventmesh-management",
      "RequireAuthentication": false,
      "SigningKey": ""
    },
    "PluginDirectory": "plugins",
    "RefreshIntervalSeconds": 5
  },
  "EventMesh": {
    "ApplicationName": "eventmesh-management",
    "DefaultTransport": "rabbitmq",
    "EnableOpenTelemetry": true,
    "TransportSettings": {
      "rabbitmq": {
        "Host": "rabbitmq",
        "Port": "5672",
        "VirtualHost": "eventmesh",
        "Username": "eventmesh",
        "Password": "eventmesh",
        "ManagementUrl": "http://rabbitmq:15672"
      },
      "kafka": {
        "BootstrapServers": "kafka:9092"
      },
      "nats": {
        "Url": "nats://nats:4222",
        "MonitoringUrl": "http://nats:8222"
      },
      "redis": {
        "ConnectionString": "redis:6379"
      },
      "postgres": {
        "ConnectionString": "Host=postgres;Port=5432;Database=eventmesh;Username=eventmesh;Password=eventmesh"
      }
    }
  },
  "OpenTelemetry": {
    "OtlpEndpoint": ""
  }
}
